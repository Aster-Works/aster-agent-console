{
  "name": "@asterworks/agent-console",
  "version": "0.1.2",
  "private": false,
  "description": "Local-first AI coding agent safety, work audit, and outcome dashboard for Claude Code and Codex.",
  "type": "module",
  "license": "MIT",
  "author": "Aster Works",
  "keywords": [
    "claude-code",
    "codex",
    "ai-agent",
    "agent-safety",
    "mcp",
    "security",
    "dashboard",
    "local-first",
    "devtools",
    "aster-works"
  ],
  "homepage": "https://github.com/Aster-Works/aster-agent-console#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aster-Works/aster-agent-console.git"
  },
  "bugs": {
    "url": "https://github.com/Aster-Works/aster-agent-console/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "aster-agent": "dist-cli/index.js"
  },
  "files": [
    "dist",
    "dist-cli",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:web": "vite build",
    "build:cli": "tsup",
    "build:all": "pnpm build && pnpm build:cli",
    "preview": "vite preview",
    "serve": "tsx src/server/start.ts",
    "aster-agent": "tsx src/cli/index.ts",
    "dashboard": "tsx src/cli/index.ts dashboard",
    "doctor": "tsx src/cli/index.ts doctor",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "typecheck:all": "pnpm typecheck && pnpm typecheck:server",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "commander": "^15.0.0",
    "hono": "^4.12.27",
    "lucide-react": "^0.469.0",
    "picocolors": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c"
}
